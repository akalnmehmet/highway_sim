<routes>
    <!-- Arka plan trafigi: IDM + MOBIL -->
    <vType id="traffic_car" length="5.0" maxSpeed="35.0"
           accel="2.4" decel="5.0"
           carFollowModel="IDM" lcModel="MOBIL"
           guiShape="passenger" color="yellow"/>

    <!-- Leader car: biraz daha yavas, ego'yu zorlar -->
    <vType id="leader_type" length="5.0" maxSpeed="25.0"
           accel="2.0" decel="5.0"
           carFollowModel="IDM" lcModel="MOBIL"
           guiShape="passenger" color="blue"/>

    <!-- Ego: DDQN + NMPC tarafindan kontrol edilir -->
    <vType id="ego_car" length="5.0" maxSpeed="35.0"
           accel="2.4" decel="5.0"
           carFollowModel="IDM"
           guiShape="passenger" color="red"/>

    <route id="route_straight" edges="highway_edge"/>

    <!-- Leader: ego'nun onunde, serit 1 -->
    <vehicle id="leader_car" type="leader_type"
             route="route_straight" depart="0.0"
             departLane="1" departPos="100.0" departSpeed="25.0"/>

    <!-- Arka plan trafigi: 1500 arac/saat -->
    <flow id="background_traffic" type="traffic_car"
          route="route_straight" begin="0" end="1000"
          vehsPerHour="1500"
          departLane="random" departSpeed="random" departPos="random"/>

    <!-- Ego: trafigin icinde rastgele pozisyonda baslar -->
    <vehicle id="ego" type="ego_car"
             route="route_straight" depart="5.0"
             departLane="random" departPos="random" departSpeed="random"/>
</routes>